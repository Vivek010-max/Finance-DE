<file path="fastapi/index.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Titan Wealth Engine</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white font-sans h-screen flex flex-col">

    <header class="p-6 border-b border-gray-800 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-blue-400">TITAN AI</h1>
        <span class="text-xs bg-green-900 text-green-300 px-2 py-1 rounded">V3 ENGINE ONLINE</span>
    </header>

    <main id="chat-box" class="flex-1 overflow-y-auto p-6 space-y-4">
        <div class="bg-gray-800 p-4 rounded-lg max-w-xs">
            Hello! I'm your Wealth Architect. Tell me about your income and any loans you're currently paying off.
        </div>
    </main>

    <footer class="p-4 border-t border-gray-800 bg-gray-900">
        <div class="flex gap-2">
            <input id="user-input" type="text" placeholder="Type your financial details..." 
                   class="flex-1 bg-gray-800 border-none rounded-lg p-3 focus:ring-2 focus:ring-blue-500 outline-none">
            <button onclick="sendMessage()" class="bg-blue-600 px-6 py-3 rounded-lg font-bold hover:bg-blue-500 transition">SEND</button>
        </div>
    </footer>

    <script>
        async function sendMessage() {
            const input = document.getElementById('user-input');
            const chatBox = document.getElementById('chat-box');
            if (!input.value) return;

            // Add User Message to UI
            chatBox.innerHTML += `<div class="ml-auto bg-blue-700 p-4 rounded-lg max-w-xs text-right">${input.value}</div>`;
            
            const message = input.value;
            input.value = '';

            // Talk to FastAPI
            try {
                const response = await fetch('http://localhost:8000/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message })
                });
                const data = await response.json();
                
                // Add AI Reply to UI
                chatBox.innerHTML += `<div class="bg-gray-800 p-4 rounded-lg max-w-xs">${data.reply}</div>`;
                chatBox.scrollTo(0, chatBox.scrollHeight);
            } catch (err) {
                console.error("Connection Error:", err);
            }
        }
    </script>
</body>
</html>
