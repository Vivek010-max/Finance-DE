      <div className="mb-8">
        <label className="flex justify-between text-xs text-(--text-secondary) mb-2">
          <span>Extra Monthly Payment (₹)</span>
          <span className="font-mono font-bold text-(--text-primary)">₹{extraPayment.toLocaleString()}</span>
